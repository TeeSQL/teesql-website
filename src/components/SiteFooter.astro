---
// Static footer — copyright, dstack credit with logo, GitHub + contact links.
---

<footer class="py-10 border-t border-rule">
  <div class="max-w-[860px] mx-auto px-6">
    <div class="flex justify-between items-center flex-wrap gap-4 max-md:flex-col max-md:items-center max-md:text-center">
      <div class="font-mono text-[0.72rem] text-ink-dim inline-flex items-center flex-wrap gap-x-1.5 gap-y-1 max-md:justify-center">
        <span class="whitespace-nowrap">&copy; 2026 TEESQL &middot;</span>
        <span class="inline-flex items-center gap-x-1.5 whitespace-nowrap">
          <span>Built on</span>
          <a
            href="https://github.com/Dstack-TEE/dstack"
            target="_blank"
            rel="noopener"
            aria-label="dstack"
            class="inline-flex items-center align-middle opacity-90 hover:opacity-100 transition-opacity duration-200 group"
          >
            <img
              src="/dstack-logo.svg"
              alt="dstack"
              class="h-[14px] w-auto translate-y-[1px] group-hover:translate-y-0 transition-transform duration-200"
            />
          </a>
          <span>&middot;</span>
        </span>
        <span class="whitespace-nowrap">Running inside Intel TDX</span>
      </div>
      <div class="flex gap-6 max-md:justify-center">
        <a
          href="https://github.com/TeeSQL"
          target="_blank"
          rel="noopener"
          class="font-mono text-[0.72rem] text-ink-dim no-underline hover:text-mint transition-colors"
        >
          GitHub
        </a>
        <a
          href="mailto:hello@teesql.com"
          class="font-mono text-[0.72rem] text-ink-dim no-underline hover:text-mint transition-colors"
        >
          Contact
        </a>
      </div>
    </div>
  </div>
</footer>
