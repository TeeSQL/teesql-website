---
import "../styles/globals.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "TeeSQL — Confidential Postgres",
  description = "Fully managed Postgres inside Trusted Execution Environments. Hardware-attested, encrypted, zero human access.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link
      rel="icon"
      type="image/svg+xml"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3E%3Ccircle cx='8' cy='8' r='6' fill='%2334d399'/%3E%3C/svg%3E"
    />
  </head>
  <body class="min-h-screen bg-page text-ink-body antialiased">
    <slot />
  </body>
</html>
